{
  "collections": {
    "users": {
      "description": "User profiles for both patients and caregivers",
      "fields": {
        "userId": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Display name of the user" },
        "email": { "type": "string", "description": "Email address" },
        "createdAt": { "type": "string", "description": "ISO 8601 timestamp" }
      }
    },
    "medicines": {
      "description": "Prescribed medication schedules assigned to compartments",
      "fields": {
        "medicineId": { "type": "string", "description": "Unique medicine identifier" },
        "userId": { "type": "string", "description": "The UID of the patient" },
        "medicineName": { "type": "string", "description": "Name of the drug" },
        "compartmentNumber": { "type": "number", "description": "Target compartment (1, 2, or 3)" },
        "scheduledTime": { "type": "string", "description": "HH:MM daily reminder schedule time (local format)" },
        "enabled": { "type": "boolean", "description": "Whether this reminder schedule is active" },
        "createdAt": { "type": "string", "description": "ISO 8601 timestamp" }
      }
    },
    "medicine_logs": {
      "description": "Adherence records for scheduled doses",
      "fields": {
        "logId": { "type": "string", "description": "Unique log identifier (e.g. medicineId-date)" },
        "userId": { "type": "string", "description": "Patient user ID" },
        "medicineId": { "type": "string", "description": "Linked medicine ID" },
        "scheduledTime": { "type": "string", "description": "ISO 8601 timestamp of scheduled intake" },
        "takenTime": { "type": "string", "description": "ISO 8601 timestamp of actual intake, null if missed" },
        "status": { "type": "string", "enum": ["Taken", "Missed", "Pending"], "description": "Status node" }
      }
    },
    "device_status": {
      "description": "Real-time state and telemetry reports from the ESP32 box",
      "fields": {
        "userId": { "type": "string", "description": "Linked patient UID" },
        "esp32Connected": { "type": "boolean", "description": "Connection state heartbeat check" },
        "lastSeen": { "type": "string", "description": "ISO 8601 timestamp of last heartbeat" },
        "weightValue": { "type": "number", "description": "Current strain gauge reading (grams)" },
        "currentCompartment": { "type": "number", "description": "Active alert compartment number, 0 if none" },
        "buzzerStatus": { "type": "boolean", "description": "Buzzer active flag" },
        "ledStatus": { "type": "array", "items": { "type": "boolean" }, "description": "State array of the 3 compartment LEDs" }
      }
    },
    "notifications": {
      "description": "Push alerts and log histories for user access",
      "fields": {
        "notificationId": { "type": "string", "description": "Unique alert ID" },
        "userId": { "type": "string", "description": "Recipient UID" },
        "title": { "type": "string", "description": "Push notification header" },
        "message": { "type": "string", "description": "Notification body" },
        "timestamp": { "type": "string", "description": "ISO 8601 timestamp" },
        "read": { "type": "boolean", "description": "Whether the user has read this notification in app" }
      }
    }
  }
}
